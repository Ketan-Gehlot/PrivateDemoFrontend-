# Shared
NODE_ENV=development

# API
USE_MOCK_DATA=false
API_PORT=8080
API_URL=http://localhost:8080
WEB_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/koinx_tlh?schema=public
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
DEFAULT_CURRENCY=inr
SHORT_TERM_TAX_RATE=0.30
LONG_TERM_TAX_RATE=0.125

# Optional seed. Values are provided by you, not static app data.
SEED_USER_EMAIL=investor@example.com
SEED_USER_PASSWORD=ChangeMe123!
SEED_USER_NAME=KoinX Investor
# Format: coinGeckoId:symbol:quantity:averageBuyPrice:yyyy-mm-dd,bitcoin:btc:0.25:4200000:2025-03-12
SEED_HOLDINGS=

# Web
VITE_API_URL=http://localhost:8080
